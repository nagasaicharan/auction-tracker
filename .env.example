# Express server port
PORT=3001

# Node environment. Set to "production" to serve the built client from Express.
NODE_ENV=development

# Optional path to the SQLite database file.
# Defaults to ./auction-tracker.db in the repo root.
# In production containers, set to a path on a persistent volume (e.g. /data/auction-tracker.db).
# DB_PATH=/data/auction-tracker.db

# Optional: bootstrap Nellis cookie string.
# Prefer logging in through the app; do not commit real cookies.
NELLIS_COOKIES=YOUR_NELLIS_COOKIES_HERE
